# Copy to .env and fill in. .env is gitignored — never commit real values.

# Lambda Cloud API key (cloud.lambda.ai -> API keys)
LAMBDA_API_KEY=

# Filesystem S3 Adapter credentials (cloud.lambda.ai -> S3 Adapter Keys)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional: Tailscale auth key. If absent, "tailscale" connection mode is
# unavailable and launches requesting it are rejected with a clear error.
TAILSCALE_AUTHKEY=
