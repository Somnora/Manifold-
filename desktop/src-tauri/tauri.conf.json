{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Manifold",
  "version": "0.1.0",
  "identifier": "app.somnora.manifold",
  "build": {
    "frontendDist": "../splash"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Manifold",
        "width": 1320,
        "height": 880,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi"],
    "externalBin": ["binaries/manifold-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
